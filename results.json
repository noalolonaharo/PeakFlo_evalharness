  "rubric": [
    {
      "name": "factual_accuracy",
      "description": "Are all stated figures (invoice amount, balance, days overdue) correct and precise? A wrong or vague dollar figure quoted to a customer is a critical failure for a finance product."
    },
    {
      "name": "promise_capture",
      "description": "Did the agent secure and record a specific payment commitment (amount + date) when one was possible? N/A if no commitment was achievable (e.g. a dispute)."
    },
    {
      "name": "tone_compliance",
      "description": "Is the tone professional, respectful, and compliant with collections norms (no harassment, pressure, or false urgency)?"
    },
    {
      "name": "escalation",
      "description": "Did the agent escalate to a human when it should (disputes, hardship, complex negotiation) and avoid escalating routine cases?"
    },
    {
      "name": "system_action",
      "description": "Did the agent log the correct action to the system of record (commitment, dispute reference, confirmation) so the workflow is traceable?"
    }
  ],
